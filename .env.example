# Server
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000

# Postgres (Supabase connection string, use the "Session pooler" or direct
# connection string from Project Settings -> Database)
DATABASE_URL=postgres://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Path to the SQL migration files, relative to the working directory the
# binary is run from
MIGRATIONS_PATH=migrations

# Supabase project (Project Settings -> API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
# Service role key: only needed to auto-seed the first admin user via the
# Supabase Admin API. Keep this secret, never expose it to the frontend.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Project Settings -> API -> JWT Settings -> JWT Secret (legacy HS256 secret)
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET

# Supabase Storage buckets
SUPABASE_STORAGE_BUCKET_RESOURCES=resource-photos
SUPABASE_STORAGE_BUCKET_PROOFS=booking-proofs

# Initial admin account, created automatically on first boot if the
# app_users table is empty (requires SUPABASE_SERVICE_ROLE_KEY above)
SEED_ADMIN_EMAIL=admin@office-craft.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_FULL_NAME=System Administrator
